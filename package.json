  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "qrcode-terminal": "^0.12.0",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.7"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-razorpay",
          "react-native-vector-icons",
          "expo-modules-jsi"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:int": "bash scripts/run-integration-tests.sh",
    "test:int:coverage": "bash scripts/run-integration-tests.sh --coverage",
    "test:int:up": "bash scripts/run-integration-tests.sh --keep",
    "test:int:coverage:up": "bash scripts/run-integration-tests.sh --coverage --keep",
    "test:int:down": "bash scripts/run-integration-tests.sh --down",
    "test:e2e": "maestro test .maestro/flows",
    "test:e2e:studio": "maestro studio",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test",
    "lint": "eslint src/ --max-warnings=0",
    "test:e2e:ci": "maestro test .maestro/flows",
    "screenshots": "bash scripts/capture-screenshots.sh",
    "screenshots:android": "bash scripts/capture-screenshots.sh --android-only",
    "screenshots:clean": "bash scripts/capture-screenshots.sh --clean",
    "screenshots:studio": "maestro studio",
    "screenshots:guide": "echo 'For iOS capture, run: maestro test .maestro/flows/screenshots/capture.yaml --app-id host.exp.Exponent'",
    "validate:imports": "node scripts/validate-imports.mjs",
    "doctor": "npx react-doctor@latest"
  },
  "private": true
}
