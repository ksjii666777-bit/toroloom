    "@testing-library/react-native": "^13.3.3",
    "babel-preset-expo": "~56.0.0",
    "date-fns": "^4.3.0",
    "expo": "~56.0.15",
    "expo-background-fetch": "~56.0.21",
    "expo-clipboard": "~56.0.4",
