{
  "expo": {
    "name": "Toroloom",
    "slug": "Toroloom",
    "version": "1.0.0",
    "scheme": "toroloom",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0F19",
    "primaryColor": "#3B82F6",
    "description": "Toroloom — AI-powered trading & investment platform. F&O options chain with Greeks, social copy trading, portfolio analytics, and KYC.",
    
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.toroloom.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:toroloom.com"
      ],
      "infoPlist": {
        "NSFaceIDUsageDescription": "Toroloom uses Face ID to secure your account and authorize trades.",
        "NSPhotoLibraryUsageDescription": "Toroloom needs access to your photo library to upload profile pictures and document scans for KYC verification.",
        "NSCameraUsageDescription": "Toroloom uses the camera for Aadhaar eKYC verification and QR code scanning.",
        "NSMicrophoneUsageDescription": "Toroloom uses the microphone for voice commands and voice search."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1117",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.toroloom.app",
      "backgroundColor": "#0D1117",
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "toroloom.com",
              "pathPrefix": "/signup"
            }
          ]
        }
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "backgroundColor": "#0D1117",
      "description": "Toroloom — AI-powered trading & investment platform",
      "name": "Toroloom",
      "lang": "en-IN",
      "scope": "/",
      "shortName": "Toroloom",
      "display": "standalone",
      "orientation": "any",
      "themeColor": "#0D1117"
    },

    "plugins": [
      "expo-sharing",
      "@react-native-firebase/app",
      "@react-native-firebase/analytics",
      "expo-font",
      "@sentry/react-native",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3B82F6"
        }
      ],
      "./plugins/withToroloomWidgets"
    ],

    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },

    "extra": {
      "eas": {
        "projectId": "516f5031-c683-43e5-a463-f714660154b0"
      }
    },

    "owner": "hgdghdghh",

    "platforms": ["ios", "android"]
  }
}
