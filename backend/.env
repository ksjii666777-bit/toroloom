# Toroloom Backend Environment Configuration

# Server
PORT=3000
NODE_ENV=development

# Storage Backend: memory | postgres | mongodb
STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://toroloom:toroloom_dev@localhost:5432/toroloom
MONGODB_URI=mongodb://toroloom:toroloom_dev@localhost:27017/toroloom?authSource=admin
MONGODB_DB_NAME=toroloom

# Broker Mode: mock | zerodha | angel
BROKER=mock
DATA_SOURCE=mock

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# Zerodha Kite Connect
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REQUEST_TOKEN=

# Angel One SmartAPI
ANGEL_CLIENT_ID=
ANGEL_API_KEY=
ANGEL_ACCESS_TOKEN=
ANGEL_PASSWORD=
ANGEL_TOTP=
