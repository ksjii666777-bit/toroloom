# ============================================================================
# Toroloom Backend — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# Docker Compose defaults (for local dev):
#   PostgreSQL:  postgresql://toroloom:toroloom_dev@localhost:5432/toroloom
#   MongoDB:     mongodb://toroloom:toroloom_dev@localhost:27017/toroloom?authSource=admin
# ============================================================================

# ──── Server ────
PORT=3000
NODE_ENV=development

# ──── Authentication ────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ──── Data Source ────
# 'mock' — Use simulated data (no broker connection required)
# 'live' — Connect to real broker APIs
DATA_SOURCE=mock

# ──── Broker ────
# 'mock'     — MockBroker (default, no keys required)
# 'zerodha'  — Zerodha Kite API
# 'angel'    — Angel One Smart API
BROKER=mock

# Zerodha API credentials (required when BROKER=zerodha)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# Angel One API credentials (required when BROKER=angel)
ANGEL_CLIENT_ID=
ANGEL_API_KEY=
ANGEL_ACCESS_TOKEN=

# ──── Storage Backend ────
# 'memory'   → InMemoryStorage (default, no database required)
# 'postgres' → PostgreSQLStorage (requires DATABASE_URL)
# 'mongodb'  → MongoDBStorage (requires MONGODB_URI + MONGODB_DB_NAME)
STORAGE_BACKEND=memory

# PostgreSQL connection (required when STORAGE_BACKEND=postgres)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://toroloom:toroloom_dev@localhost:5432/toroloom

# MongoDB connection (required when STORAGE_BACKEND=mongodb)
# Format: mongodb://user:password@host:port/database?authSource=admin
MONGODB_URI=mongodb://toroloom:toroloom_dev@localhost:27017/toroloom?authSource=admin
MONGODB_DB_NAME=toroloom
