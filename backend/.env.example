# ============================================================================
# Toroloom Backend — Environment Configuration Template
# ============================================================================
# Copy this file to backend/.env and fill in your credentials:
#   cp backend/.env.example backend/.env
# ============================================================================

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Broker — set to 'angel' for Angel One, 'mock' for development
BROKER=mock

# Data Source — 'live' for real API, 'mock' for simulated data
DATA_SOURCE=mock

# Storage Backend
#   memory   -> InMemoryStorage (default, no deps)
#   postgres -> PostgreSQLStorage (requires DATABASE_URL)
#   mongodb  -> MongoDBStorage (requires MONGODB_URI + MONGODB_DB_NAME)
STORAGE_BACKEND=memory
DATABASE_URL=postgresql://toroloom:toroloom_dev@localhost:5432/toroloom
MONGODB_URI=mongodb://toroloom:toroloom_dev@localhost:27017/toroloom?authSource=admin
MONGODB_DB_NAME=toroloom

# Zerodha Kite Connect
# Get credentials: https://kite.trade/connect/login
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REQUEST_TOKEN=

# Angel One SmartAPI
# Get credentials: https://smartapi.angelbroking.com/
# NEVER commit real credentials to git. Use .env only.
ANGEL_CLIENT_ID=
ANGEL_API_KEY=
ANGEL_PASSWORD=
ANGEL_TOTP=
# ANGEL_ACCESS_TOKEN=   (optional, if you have an existing token)

# Groww Trade API
# Get credentials: https://groww.in/trade-api
GROWW_API_KEY=
GROWW_ACCESS_TOKEN=

# Sentry (error tracking)
# Get DSN from: https://sentry.io/settings/{org}/projects/{project}/keys/
# Leave empty to disable Sentry entirely.
SENTRY_DSN=

# Redis (pub/sub for cross-worker sync)
# Format: redis://[:password@]host[:port][/db]
REDIS_URL=
