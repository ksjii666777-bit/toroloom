{
  "name": "toroloom-backend",
  "version": "1.0.0",
  "description": "Toroloom backend API server with broker integration (Zerodha Kite Connect / Angel One SmartAPI)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cluster": "CLUSTER_MODE=1 node dist/index.js",
    "start:cluster:prod": "NODE_ENV=production CLUSTER_MODE=1 node dist/index.js",
    "test": "vitest run --exclude='**/*.int.test.ts'",
    "lint": "eslint src/**/*.ts",
    "test:int": "bash ../scripts/run-integration-tests.sh",
    "test:int:coverage": "bash ../scripts/run-integration-tests.sh --coverage",
    "test:int:up": "bash ../scripts/run-integration-tests.sh --keep",
    "test:int:coverage:up": "bash ../scripts/run-integration-tests.sh --coverage --keep",
    "test:int:down": "bash ../scripts/run-integration-tests.sh --down"
  },
  "dependencies": {
    "@sentry/node": "^10.56.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "kiteconnect": "^5.3.0",
    "mongodb": "^7.2.0",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "smartapi-javascript": "^1.0.27",
    "speakeasy": "^2.0.0",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.6.3",
    "vitest": "^4.1.7"
  }
}
