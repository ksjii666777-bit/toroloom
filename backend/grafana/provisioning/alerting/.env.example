# ============================================================================
# Toroloom Grafana Alerting — Required Environment Variables
# ============================================================================
#
# These variables are referenced by the contact_points.yml provisioning file.
# Set them in your Grafana container environment or .env file.
#
# Usage:
#   docker run ... \
#     -e SLACK_WEBHOOK_URL=https://hooks.slack.com/services/... \
#     -e PAGERDUTY_INTEGRATION_KEY=abc123def456 \
#     grafana/grafana-enterprise:latest
# ============================================================================

# Slack Incoming Webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
# Example: https://hooks.slack.com/services/T00/B00/xxxxxxxx
SLACK_WEBHOOK_URL=

# PagerDuty Events API v2 Integration Key
# Create one in PagerDuty under: Integrations > Generic Events API v2
# Example: abcdef1234567890abcdef1234567890
PAGERDUTY_INTEGRATION_KEY=
