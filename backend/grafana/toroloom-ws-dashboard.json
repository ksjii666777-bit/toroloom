{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for Toroloom WebSocket metrics",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "5.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "title": "Toroloom — WebSocket Connections",
  "description": "Real-time WebSocket connection monitoring for the Toroloom trading platform. Tracks active connections, per-user distribution, subscription health, and tick throughput.",
  "tags": ["toroloom", "websocket", "connections", "trading"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "15s",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "collapsed": false,
      "title": "Overview",
      "panels": [
        {
          "id": 1,
          "type": "stat",
          "title": "Total Connections",
          "description": "Total active authenticated WebSocket connections across all users.",
          "gridPos": { "h": 8, "w": 4, "x": 0, "y": 0 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 200 },
                  { "color": "red", "value": 500 }
                ]
              },
              "unit": "short",
              "mappings": [],
              "min": 0,
              "max": 1000,
              "noValue": "0"
            },
            "overrides": []
          },
          "options": {
            "colorMode": "background",
            "graphMode": "area",
            "justifyMode": "auto",
            "orientation": "horizontal",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "textMode": "auto"
          },
          "targets": [
            {
              "expr": "toroloom_ws_total_connections",
              "legendFormat": "Connections",
              "refId": "A"
            }
          ]
        },
        {
          "id": 2,
          "type": "stat",
          "title": "Authenticated Users",
          "description": "Number of distinct authenticated users with at least one active WebSocket connection.",
          "gridPos": { "h": 8, "w": 4, "x": 4, "y": 0 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 100 },
                  { "color": "red", "value": 250 }
                ]
              },
              "unit": "short",
              "mappings": [],
              "min": 0,
              "noValue": "0"
            },
            "overrides": []
          },
          "options": {
            "colorMode": "background",
            "graphMode": "area",
            "justifyMode": "auto",
            "orientation": "horizontal",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "textMode": "auto"
          },
          "targets": [
            {
              "expr": "toroloom_ws_authenticated_users",
              "legendFormat": "Users",
              "refId": "A"
            }
          ]
        },
        {
          "id": 3,
          "type": "stat",
          "title": "Alerted Users",
          "description": "Users who have exceeded the max concurrent connection threshold (default: 5).",
          "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 1 },
                  { "color": "red", "value": 5 }
                ]
              },
              "unit": "short",
              "mappings": [
                {
                  "type": "value",
                  "value": "0",
                  "text": "0 — All Clear"
                },
                {
                  "type": "value",
                  "value": "1",
                  "text": "⚠ 1 User Alerted"
                }
              ],
              "min": 0,
              "noValue": "0"
            },
            "overrides": []
          },
          "options": {
            "colorMode": "background",
            "graphMode": "none",
            "justifyMode": "auto",
            "orientation": "horizontal",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "textMode": "auto"
          },
          "targets": [
            {
              "expr": "toroloom_ws_alerted_users",
              "legendFormat": "Alerted",
              "refId": "A"
            }
          ]
        },
        {
          "id": 4,
          "type": "stat",
          "title": "Ticks / sec",
          "description": "Running rate of price ticks delivered to clients over the last 5 minutes.",
          "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "dark-red", "value": null },
                  { "color": "orange", "value": 1 },
                  { "color": "green", "value": 50 }
                ]
              },
              "unit": "cps",
              "mappings": [],
              "min": 0,
              "noValue": "0 cps"
            },
            "overrides": []
          },
          "options": {
            "colorMode": "background",
            "graphMode": "area",
            "justifyMode": "auto",
            "orientation": "horizontal",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "textMode": "auto"
          },
          "targets": [
            {
              "expr": "sum(rate(toroloom_ws_ticks_total[$__rate_interval]))",
              "legendFormat": "Ticks/s",
              "refId": "A"
            }
          ]
        }
      ]
    },
    {
      "collapsed": false,
      "title": "Trends",
      "panels": [
        {
          "id": 5,
          "type": "timeseries",
          "title": "Connections & Users Over Time",
          "description": "Total active connections vs distinct authenticated users. A widening gap indicates multi-tab usage.",
          "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "axisCenteredZero": false,
                "axisColorMode": "text",
                "axisLabel": "",
                "axisPlacement": "auto",
                "barAlignment": 0,
                "drawStyle": "line",
                "fillOpacity": 15,
                "gradientMode": "hue",
                "hideFrom": {
                  "legend": false,
                  "tooltip": false,
                  "viz": false
                },
                "lineInterpolation": "smooth",
                "lineWidth": 2,
                "pointSize": 4,
                "scaleDistribution": {
                  "type": "linear"
                },
                "showPoints": "never",
                "spanNulls": false,
                "stacking": {
                  "group": "A",
                  "mode": "none"
                },
                "thresholdsStyle": {
                  "mode": "off"
                }
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null }
                ]
              },
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "calcs": ["lastNotNull", "max", "mean"],
              "displayMode": "table",
              "placement": "bottom",
              "showLegend": true
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "expr": "toroloom_ws_total_connections",
              "legendFormat": "Total Connections",
              "refId": "A"
            },
            {
              "expr": "toroloom_ws_authenticated_users",
              "legendFormat": "Authenticated Users",
              "refId": "B"
            }
          ]
        },
        {
          "id": 6,
          "type": "timeseries",
          "title": "Ticks Per Second",
          "description": "Aggregate tick delivery rate across all users. Drops to zero indicate a ticker stall.",
          "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "axisCenteredZero": false,
                "axisColorMode": "text",
                "axisLabel": "ticks / sec",
                "axisPlacement": "auto",
                "barAlignment": 0,
                "drawStyle": "line",
                "fillOpacity": 20,
                "gradientMode": "opacity",
                "hideFrom": {
                  "legend": false,
                  "tooltip": false,
                  "viz": false
                },
                "lineInterpolation": "smooth",
                "lineWidth": 2,
                "pointSize": 4,
                "scaleDistribution": {
                  "type": "linear"
                },
                "showPoints": "never",
                "spanNulls": true,
                "stacking": {
                  "group": "A",
                  "mode": "none"
                },
                "thresholdsStyle": {
                  "mode": "line"
                }
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "green", "value": 1 }
                ]
              },
              "unit": "cps"
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": "/.*stall.*/i"
                },
                "properties": [
                  {
                    "id": "custom.fillOpacity",
                    "value": 0
                  },
                  {
                    "id": "custom.lineWidth",
                    "value": 1
                  },
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "dark-red"
                    }
                  }
                ]
              }
            ]
          },
          "options": {
            "legend": {
              "calcs": ["lastNotNull", "max", "mean"],
              "displayMode": "table",
              "placement": "bottom",
              "showLegend": true
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "expr": "sum(rate(toroloom_ws_ticks_total[$__rate_interval]))",
              "legendFormat": "Total Ticks/s",
              "refId": "A"
            },
            {
              "expr": "sum(rate(toroloom_ws_ticks_total[5m])) == 0 and sum(toroloom_ws_total_connections) > 0",
              "legendFormat": "⚠ STALL (0 ticks with connections)",
              "refId": "B"
            }
          ]
        }
      ]
    },
    {
      "collapsed": false,
      "title": "Per-User Details",
      "panels": [
        {
          "id": 7,
          "type": "table",
          "title": "Connection Count by User",
          "description": "Current WebSocket connections per user. Sorted by connection count descending. Values exceeding 5 trigger alerts.",
          "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "custom": {
                "align": "auto",
                "displayMode": "auto",
                "minWidth": 120
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 4 },
                  { "color": "red", "value": 6 }
                ]
              },
              "unit": "short"
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "User ID" },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 300
                  }
                ]
              },
              {
                "matcher": { "id": "byName", "options": "Connections" },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 150
                  },
                  {
                    "id": "custom.displayMode",
                    "value": "color-background-solid"
                  }
                ]
              }
            ]
          },
          "options": {
            "footer": {
              "countRows": false,
              "enablePagination": false,
              "fields": "",
              "reducer": ["sum"],
              "show": true
            },
            "sortBy": [
              {
                "displayName": "Connections",
                "desc": true
              }
            ],
            "showTypeIcons": false
          },
          "targets": [
            {
              "expr": "toroloom_ws_user_connections{user_id=~\"$user_id\"}",
              "legendFormat": "{{user_id}}",
              "refId": "A",
              "format": "table"
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "Time": true,
                  "__name__": true,
                  "instance": true,
                  "job": true
                },
                "indexByName": {
                  "user_id": 0,
                  "Value": 1
                },
                "renameByName": {
                  "user_id": "User ID",
                  "Value": "Connections"
                }
              }
            }
          ]
        },
        {
          "id": 8,
          "type": "table",
          "title": "Active Subscriptions by User",
          "description": "Number of symbols each user is currently subscribed to (aggregated across all their tabs).",
          "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "custom": {
                "align": "auto",
                "displayMode": "auto",
                "minWidth": 120
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 20 },
                  { "color": "red", "value": 50 }
                ]
              },
              "unit": "short"
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Symbols" },
                "properties": [
                  {
                    "id": "custom.displayMode",
                    "value": "color-background-solid"
                  }
                ]
              }
            ]
          },
          "options": {
            "footer": {
              "countRows": false,
              "enablePagination": false,
              "fields": "",
              "reducer": ["sum"],
              "show": true
            },
            "sortBy": [
              {
                "displayName": "Subscriptions",
                "desc": true
              }
            ],
            "showTypeIcons": false
          },
          "targets": [
            {
              "expr": "toroloom_ws_active_subscriptions{user_id=~\"$user_id\"}",
              "legendFormat": "{{user_id}}",
              "refId": "A",
              "format": "table"
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "Time": true,
                  "__name__": true,
                  "instance": true,
                  "job": true
                },
                "indexByName": {
                  "user_id": 0,
                  "Value": 1
                },
                "renameByName": {
                  "user_id": "User ID",
                  "Value": "Subscriptions"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "collapsed": false,
      "title": "Alerts & Health",
      "panels": [
        {
          "id": 9,
          "type": "timeseries",
          "title": "Per-User Connection Distribution",
          "description": "Breakdown of the top 10 users by connection count. Spikes above the threshold line indicate multi-tab abuse.",
          "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "axisCenteredZero": false,
                "axisColorMode": "text",
                "axisLabel": "",
                "axisPlacement": "auto",
                "barAlignment": 0,
                "drawStyle": "line",
                "fillOpacity": 10,
                "gradientMode": "none",
                "hideFrom": {
                  "legend": false,
                  "tooltip": false,
                  "viz": false
                },
                "lineInterpolation": "stepAfter",
                "lineWidth": 1,
                "pointSize": 2,
                "scaleDistribution": {
                  "type": "linear"
                },
                "showPoints": "never",
                "spanNulls": true,
                "stacking": {
                  "group": "A",
                  "mode": "none"
                },
                "thresholdsStyle": {
                  "mode": "dashed"
                }
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "red", "value": 5 }
                ]
              },
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "calcs": ["lastNotNull", "max"],
              "displayMode": "table",
              "placement": "bottom",
              "showLegend": true
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
          "targets": [
            {
              "expr": "topk(10, toroloom_ws_user_connections{user_id=~\"$user_id\"})",
              "legendFormat": "{{user_id}}",
              "refId": "A"
            }
          ]
        },
        {
          "id": 10,
          "type": "gauge",
          "title": "Alerted Users Gauge",
          "description": "Current number of users in alert state. An alert fires when a user exceeds 5 concurrent connections.",
          "gridPos": { "h": 10, "w": 6, "x": 12, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 1 },
                  { "color": "red", "value": 5 }
                ]
              },
              "mappings": [],
              "min": 0,
              "max": 10,
              "unit": "short",
              "noValue": "0"
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "showThresholdLabels": true,
            "showThresholdMarkers": true,
            "orientation": "auto"
          },
          "targets": [
            {
              "expr": "toroloom_ws_alerted_users",
              "legendFormat": "Alerted Users",
              "refId": "A"
            }
          ]
        },
        {
          "id": 11,
          "type": "stat",
          "title": "Connection Health Status",
          "description": "Overall health score based on the ratio of users to connections. A high ratio means heavy multi-tab usage.",
          "gridPos": { "h": 10, "w": 6, "x": 18, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 1.5 },
                  { "color": "red", "value": 3 }
                ]
              },
              "mappings": [
                {
                  "type": "value",
                  "value": "null",
                  "text": "N/A — No Data"
                }
              ],
              "min": 1,
              "unit": "ratio",
              "noValue": "N/A"
            },
            "overrides": []
          },
          "options": {
            "colorMode": "background",
            "graphMode": "none",
            "justifyMode": "auto",
            "orientation": "horizontal",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "textMode": "auto"
          },
          "targets": [
            {
              "expr": "clamp_min(toroloom_ws_total_connections / toroloom_ws_authenticated_users, 1)",
              "legendFormat": "Conn/User Ratio",
              "refId": "A"
            }
          ]
        }
      ]
    },
    {
      "collapsed": false,
      "title": "Annotations",
      "panels": [
        {
          "id": 12,
          "type": "table",
          "title": "Raw Metrics Sampler",
          "description": "Raw Prometheus values for debugging. Shows the last scraped sample for each toroloom_ws metric.",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "custom": {
                "align": "auto",
                "displayMode": "auto"
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "footer": {
              "countRows": false,
              "enablePagination": false,
              "fields": "",
              "reducer": ["sum"],
              "show": false
            },
            "sortBy": [
              {
                "displayName": "Metric",
                "desc": false
              }
            ],
            "showTypeIcons": false
          },
          "targets": [
            {
              "expr": "toroloom_ws_total_connections",
              "legendFormat": "toroloom_ws_total_connections",
              "refId": "total"
            },
            {
              "expr": "toroloom_ws_authenticated_users",
              "legendFormat": "toroloom_ws_authenticated_users",
              "refId": "users"
            },
            {
              "expr": "toroloom_ws_alerted_users",
              "legendFormat": "toroloom_ws_alerted_users",
              "refId": "alerted"
            },
            {
              "expr": "sum(rate(toroloom_ws_ticks_total[$__rate_interval]))",
              "legendFormat": "rate(toroloom_ws_ticks_total)",
              "refId": "ticks"
            },
            {
              "expr": "count(toroloom_ws_user_connections)",
              "legendFormat": "count(toroloom_ws_user_connections)",
              "refId": "user_count"
            },
            {
              "expr": "count(toroloom_ws_active_subscriptions)",
              "legendFormat": "count(toroloom_ws_active_subscriptions)",
              "refId": "sub_count"
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "Time": true,
                  "instance": true,
                  "job": true,
                  "__name__": true
                },
                "indexByName": {},
                "renameByName": {
                  "Metric": "Metric",
                  "Value": "Current Value"
                }
              }
            }
          ]
        }
      ]
    }
