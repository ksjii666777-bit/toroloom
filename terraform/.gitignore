# ==============================================================================
# Toroloom — Terraform .gitignore
# ==============================================================================

# Local .terraform directories
**/.terraform/
**/.terraform.lock.hcl

# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# CLI configuration files
.terraformrc
terraform.rc

# Backend config with bucket/key values
backend.hcl

# Variable files with secrets — use terraform.tfvars.example as template
terraform.tfvars
*.auto.tfvars
