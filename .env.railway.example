# =============================================================================
# Toroloom — Railway Production Environment Variables
# =============================================================================
#
# Copy the key=value lines below into Railway Dashboard → Variables.
# Marked as ❌ REQUIRED or ⚠️ OPTIONAL per variable.
#
# Reference: backend/src/config/env.ts
# =============================================================================


# =============================================================================
# 🔐 AUTH — REQUIRED for production
# =============================================================================

# JWT signing secret. Generate with: openssl rand -base64 32
# ❌ REQUIRED — server fails to start in production without this
JWT_SECRET=

# JWT token expiry duration (default: 7d)
# ⚠️ OPTIONAL
# JWT_EXPIRES_IN=7d


# =============================================================================
# 🗄️ DATABASE — Choose ONE storage backend
# =============================================================================

# Which storage backend to use: memory | postgres | mongodb
# Default: memory (data is lost on restart — NOT suitable for production)
# ⚠️ OPTIONAL (defaults to 'memory')
# STORAGE_BACKEND=memory

# PostgreSQL connection string (required if STORAGE_BACKEND=postgres)
# Auto-injected by Railway PostgreSQL plugin as DATABASE_URL
# ❌ REQUIRED if using PostgreSQL
# DATABASE_URL=postgresql://user:pass@host:5432/toroloom

# MongoDB connection string (required if STORAGE_BACKEND=mongodb)
# ⚠️ OPTIONAL
# MONGODB_URI=mongodb://user:pass@host:27017/toroloom

# MongoDB database name
# ⚠️ OPTIONAL
# MONGODB_DB_NAME=toroloom


# =============================================================================
# 💳 PAYMENTS — Razorpay
# =============================================================================

# Razorpay API keys from https://dashboard.razorpay.com/app/keys
# Test mode keys start with rzp_test_
# ❌ REQUIRED for real payments (mock fallback if missing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook secret for verifying Razorpay webhook signatures.
# Set this value in Razorpay Dashboard → Settings → Webhooks
# Webhook endpoint: POST /api/payments/webhook
# ❌ REQUIRED for automatic subscription activation via webhooks
RAZORPAY_WEBHOOK_SECRET=


# =============================================================================
# 🧠 AI — Multi-Provider
# =============================================================================

# AI provider: openrouter | google
# Default: openrouter
# ⚠️ OPTIONAL — returns mock/fallback data if not configured
# AI_PROVIDER=openrouter

# OpenRouter API key (recommended — supports multiple models)
# Get: https://openrouter.ai/keys
# ⚠️ OPTIONAL
# OPENROUTER_API_KEY=

# OpenRouter model to use (default: google/gemini-2.0-flash-lite-001)
# ⚠️ OPTIONAL
# OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001

# Google Gemini API key (alternative to OpenRouter)
# Get: https://aistudio.google.com/app/apikey
# ⚠️ OPTIONAL
# GOOGLE_GEMINI_API_KEY=

# Google Gemini model (default: gemini-2.0-flash-lite-001)
# ⚠️ OPTIONAL
# GOOGLE_GEMINI_MODEL=gemini-2.0-flash-lite-001


# =============================================================================
# 📊 ERROR TRACKING — Sentry
# =============================================================================

# Sentry DSN for error tracking
# Get: https://sentry.io/settings/<org>/projects/<project>/keys/
# ⚠️ OPTIONAL — errors are logged to console if not set
# SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000


# =============================================================================
# ⚡ CACHE & PUB/SUB — Redis
# =============================================================================

# Redis connection URL for multi-tier caching + cross-worker pub/sub.
# Auto-injected by Railway Redis plugin as RAILWAY_REDIS_URL.
# Either REDIS_URL or RAILWAY_REDIS_URL must be set.
# ⚠️ OPTIONAL — caching degrades gracefully to in-memory fallback
# REDIS_URL=redis://default:password@host:6379


# =============================================================================
# 🏢 MULTI-TENANT — Per-Tenant Razorpay Keys
# =============================================================================

# Each tenant can have their own Razorpay keys for payment routing.
# Replace {TENANT_ID_UC} with the uppercase+underscore tenant ID.
# ⚠️ OPTIONAL — falls back to global RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET
# TENANT_{TENANT_ID_UC}_RAZORPAY_KEY_ID=
# TENANT_{TENANT_ID_UC}_RAZORPAY_KEY_SECRET=


# =============================================================================
# 🏦 BROKER CREDENTIALS — Zerodha
# =============================================================================

# ⚠️ OPTIONAL — only needed if using Zerodha broker
# ZERODHA_API_KEY=
# ZERODHA_API_SECRET=
# ZERODHA_ACCESS_TOKEN=
# ZERODHA_REQUEST_TOKEN=


# =============================================================================
# 🏦 BROKER CREDENTIALS — Angel One
# =============================================================================

# ⚠️ OPTIONAL — only needed if using Angel One broker
# ANGEL_CLIENT_ID=
# ANGEL_API_KEY=
# ANGEL_ACCESS_TOKEN=
# ANGEL_PASSWORD=
# ANGEL_TOTP=


# =============================================================================
# 🏦 BROKER CREDENTIALS — Groww
# =============================================================================

# ⚠️ OPTIONAL — only needed if using Groww broker
# GROWW_API_KEY=
# GROWW_ACCESS_TOKEN=


# =============================================================================
# ⚙️ OPERATIONAL — Safe Defaults
# =============================================================================

# Server port (default: 3000)
# ⚠️ OPTIONAL
# PORT=3000

# Environment: development | production | test
# Railway sets this automatically to production
# ⚠️ OPTIONAL
# NODE_ENV=production

# Data source: mock | live
# Default: mock
# ⚠️ OPTIONAL
# DATA_SOURCE=live

# Active broker: mock | zerodha | angel | groww
# Default: mock
# ⚠️ OPTIONAL
# BROKER=mock

# Enable subscription gating middleware globally (true | false)
# ⚠️ OPTIONAL — defaults to disabled
# SUBSCRIPTION_GATING_ENABLED=false

# Enable cluster mode for multi-core processing (true | false)
# Requires Redis for cross-worker IPC
# ⚠️ OPTIONAL
# CLUSTER_MODE=false

# Disable cache middleware (1 = disabled)
# ⚠️ OPTIONAL
# DISABLE_CACHE=0
