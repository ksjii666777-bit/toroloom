# ============================================================================
# Toroloom — Environment Variables (copy to .env and edit)
# ============================================================================
# Copy this file:
#   cp .env.example .env
# Then edit .env with your production values.
# Never commit .env to Git (it's in .gitignore).

# ── Required ────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-hex-string

# ── Storage (default: memory — no database needed) ─────────────────────────
# STORAGE_BACKEND=postgres
# Point to PgBouncer (port 6432) for connection pooling in production.
# For direct PostgreSQL (dev without PgBouncer): use port 5432.
# DATABASE_URL=postgresql://toroloom:your_password@pgbouncer:6432/toroloom
# POSTGRES_PASSWORD=your_password

# STORAGE_BACKEND=mongodb
# MONGODB_URI=mongodb://toroloom:your_password@mongodb:27017
# MONGO_PASSWORD=your_password
# MONGODB_DB_NAME=toroloom

# ── Broker (default: mock — no real trading) ───────────────────────────────
# BROKER=zerodha
# DATA_SOURCE=live
# ZERODHA_API_KEY=your_key
# ZERODHA_API_SECRET=your_secret
# ZERODHA_ACCESS_TOKEN=your_token

# BROKER=angel
# ANGEL_CLIENT_ID=your_client_id
# ANGEL_API_KEY=your_api_key
# ANGEL_ACCESS_TOKEN=your_token
# ANGEL_PASSWORD=your_password
# ANGEL_TOTP=your_totp_secret

# ── Optional ────────────────────────────────────────────────────────────────
# JWT_EXPIRES_IN=7d
