# ═══════════════════════════════════════════════════════════════════════════
# Toroloom — Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
# WHITE-LABEL SETUP:
#   When selling this app to a buyer, they ONLY need to change these
#   environment variables. No code changes needed!
#
# HOW TO USE:
#   Copy this file to .env.local for local development:
#     cp .env.example .env.local
#
#   For production builds (EAS), set these in eas.json build profiles
#   under the "env" section for each profile.
#
# ═══════════════════════════════════════════════════════════════════════════

# ──── REQUIRED ─────────────────────────────────────────────────────────────
# Backend API URL — YOUR Railway domain goes here.
# This is the ONLY thing your frontend needs to know.
# Example: https://your-app.up.railway.app/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ──── OPTIONAL ─────────────────────────────────────────────────────────────

# Sentry error tracking DSN (optional, for production monitoring)
EXPO_PUBLIC_SENTRY_DSN=

# Referral program base URL (optional, defaults to app domain)
EXPO_PUBLIC_REFERRAL_BASE_URL=https://toroloom.com

# App name for white-labeling (optional, defaults to "Toroloom")
EXPO_PUBLIC_APP_NAME=Toroloom

# Support email for the app (optional)
EXPO_PUBLIC_SUPPORT_EMAIL=support@toroloom.com

# ═══════════════════════════════════════════════════════════════════════════
# NOTE: All sensitive credentials (Razorpay keys, AI API keys, broker keys,
# database URLs, JWT secrets) live on the BACKEND environment variables.
# The frontend NEVER has direct access to these — it only talks to the
# backend API via EXPO_PUBLIC_API_URL.
# ═══════════════════════════════════════════════════════════════════════════
